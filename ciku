<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Secure GitHub Pages Template</title>

<!-- Security Policies -->
<meta http-equiv="Content-Security-Policy" content="default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self';">
<meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin">
<meta http-equiv="X-Content-Type-Options" content="nosniff">

<style>
body{font-family:Arial,sans-serif;margin:0;padding:0;background:#f7f7f7;color:#222}
header{padding:30px;text-align:center;background:#111;color:#fff}
main{max-width:1000px;margin:auto;padding:20px}
.card{background:#fff;padding:20px;border-radius:10px;margin:15px 0;box-shadow:0 2px 8px rgba(0,0,0,.08)}
footer{text-align:center;padding:20px}
</style>
</head>
<body>
<header>
<h1>Secure Website Template</h1>
<p>Single-file HTML for GitHub Pages</p>
</header>

<main>
<div class="card">
<h2>Security Features</h2>
<ul>
<li>Content Security Policy (CSP)</li>
<li>Clickjacking Protection</li>
<li>Referrer Protection</li>
<li>No external scripts</li>
<li>HTTPS-ready</li>
<li>Input validation example</li>
</ul>
</div>

<div class="card">
<h2>Contact Form Demo</h2>
<form id="contactForm">
<input type="text" id="name" placeholder="Name" required>
<button type="submit">Submit</button>
</form>
<p id="msg"></p>
</div>

<div class="card">
<h2>Deployment Checklist</h2>
<ul>
<li>Enable HTTPS in GitHub Pages settings</li>
<li>Use strong passwords and 2FA on GitHub</li>
<li>Do not store API keys in HTML</li>
<li>Review third‑party scripts before use</li>
<li>Keep dependencies updated</li>
</ul>
</div>
</main>

<footer>
&copy; 2026 Secure GitHub Website
</footer>

<script>
document.getElementById('contactForm').addEventListener('submit', function(e){
 e.preventDefault();
 const name=document.getElementById('name').value.trim();
 if(!/^[a-zA-Z\s]{1,50}$/.test(name)){
   document.getElementById('msg').textContent='Invalid input';
   return;
 }
 document.getElementById('msg').textContent='Input accepted safely.';
});
</script>
</body>
</html>
